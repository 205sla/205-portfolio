---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import WorksGallery from '@/components/WorksGallery.astro';
import Awards from '@/components/Awards.astro';
import ExternalChannels from '@/components/ExternalChannels.astro';

const projects = await getCollection('projects');
---
<BaseLayout title="205 — 이영호 포트폴리오">

<!-- Scroll progress bar -->
<div class="scroll-bar"><i id="scroll-i"></i></div>

<!-- Right-side scroll dots -->
<nav class="scroll-dots" aria-label="Section navigation">
  <a href="#hero" data-target="hero" class="active"><span>Hero</span></a>
  <a href="#about" data-target="about"><span>About</span></a>
  <a href="#skills" data-target="skills"><span>Skills</span></a>
  <a href="#works" data-target="works"><span>Works</span></a>
  <a href="#highlights" data-target="highlights"><span>Highlights</span></a>
  <a href="#awards" data-target="awards"><span>Awards</span></a>
  <a href="#contact" data-target="contact"><span>Contact</span></a>
</nav>

<!-- ========== NAV ========== -->
<header class="nav">
  <a class="brand" href="#hero">
    <span class="num">205</span>
    <span class="name">Lee&nbsp;Youngho</span>
  </a>
  <ul>
    <li><a href="#about">About</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#works">Works</a></li>
    <li><a href="#highlights">Highlights</a></li>
    <li><a href="#awards">Awards</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <div class="meta">
    <span class="dot" aria-hidden="true"></span>
    <span>현재 게임 개발 학습 중</span>
  </div>
</header>

<!-- ========== HERO ========== -->
<section id="hero" class="hero">
  <div class="hero-meta">
    <div class="left">
      <span><strong>205.kr</strong> · Personal Portfolio · v2026</span>
      <span>Last updated · 2026.04.28</span>
    </div>
    <div class="right">
      <span><strong>Seoul, KR</strong> · 37.59°N 127.06°E</span>
      <span>2003.01.05 — present</span>
    </div>
  </div>

  <h1 class="hero-205" aria-label="205">
    <span class="digit">2</span><span class="digit">0</span><span class="digit">5</span>
  </h1>

  <div class="hero-character" aria-hidden="true">
    <div class="speech">안녕하세요!</div>
    <img src={`${import.meta.env.BASE_URL}assets/205-arms.png`} alt="" />
  </div>

  <div class="hero-tagline">
    <p class="lead">
      엔트리로 코딩에 입문해서, <strong>책 두 권</strong>을 쓰고
      <strong>SEF2023</strong>에서 강연까지 했습니다.
      이젠 <strong>게임 개발자</strong>로 한 걸음씩 옮겨가는 중이에요.
    </p>
    <div class="name-block">
      <div class="ko">이영호</div>
      <div class="en">YoungHo&nbsp;Lee</div>
      <div class="role">Author · Speaker · Developer</div>
    </div>
  </div>
</section>

<!-- Marquee -->
<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    <span>엔트리 자문단&nbsp;&nbsp;<i class="star">✦</i>&nbsp;&nbsp;나는야 엔트리 화가&nbsp;&nbsp;<i class="star">✦</i>&nbsp;&nbsp;나는야 엔트리 게임 개발자&nbsp;&nbsp;<i class="star">✦</i>&nbsp;&nbsp;SEF2023 연사&nbsp;&nbsp;<i class="star">✦</i>&nbsp;&nbsp;나무위키 등재&nbsp;&nbsp;<i class="star">✦</i>&nbsp;&nbsp;205&nbsp;&nbsp;<i class="star">✦</i>&nbsp;&nbsp;</span>
    <span>엔트리 자문단&nbsp;&nbsp;<i class="star">✦</i>&nbsp;&nbsp;나는야 엔트리 화가&nbsp;&nbsp;<i class="star">✦</i>&nbsp;&nbsp;나는야 엔트리 게임 개발자&nbsp;&nbsp;<i class="star">✦</i>&nbsp;&nbsp;SEF2023 연사&nbsp;&nbsp;<i class="star">✦</i>&nbsp;&nbsp;나무위키 등재&nbsp;&nbsp;<i class="star">✦</i>&nbsp;&nbsp;205&nbsp;&nbsp;<i class="star">✦</i>&nbsp;&nbsp;</span>
  </div>
</div>

<!-- ========== ABOUT ========== -->
<section id="about" class="about">
  <div class="section-head">
    <div class="label"><span class="idx">01</span>About</div>
    <h2>안녕하세요!<br/><em>엔트리로 이것저것 하는</em> <span class="accent">게임 개발자</span>입니다.</h2>
  </div>

  <div class="about-grid">
    <div class="about-text">
      <p>초등학생 시절 코딩 교육 플랫폼인 <strong>엔트리</strong>로 개발을 처음 접했습니다. 개발이 너무 즐거워서 다른 친구들에게도 이 즐거움을 알리고자 다양한 활동을 하다 보니 <strong>SEF2023</strong>에 연사로도 참여하고 책도 두 권이나 쓰게 되었습니다.</p>
      <p>엔트리로는 할 수 있는 거 다 해본 것 같아서 최근에는 <strong>게임 개발자</strong>로써 필요한 역량을 기르는데 힘쓰고 있습니다.</p>
      <div class="code-block" style="margin-top:32px;" id="codeblock">
        <div class="top">
          <i class="dot r"></i><i class="dot y"></i><i class="dot g"></i>
          <span class="file">~/205/study.cpp</span>
          <button class="runbtn" id="runbtn">▶ run</button>
        </div>
        <div class="body">
          <div id="codetype"></div>
        </div>
      </div>
    </div>

    <aside class="about-side">
      <div class="timeline">
        <h4>학력</h4>
        <a class="tl-item" href="http://www.e-kyhj.es.kr/wah/main/index.htm" target="_blank" rel="noopener">
          <div class="yr">2010 — 2015</div>
          <div class="school">화정 초등학교<span class="sub">(고양)</span></div>
        </a>
        <a class="tl-item" href="http://hwajung.ms.kr/" target="_blank" rel="noopener">
          <div class="yr">2016 — 2018</div>
          <div class="school">화정 중학교</div>
        </a>
        <a class="tl-item" href="https://hwajung.hs.kr/" target="_blank" rel="noopener">
          <div class="yr">2019 — 2021</div>
          <div class="school">화정 고등학교</div>
        </a>
        <a class="tl-item now" href="http://swcon.khu.ac.kr/" target="_blank" rel="noopener">
          <div class="yr">2022 — Now</div>
          <div class="school">경희대학교<span class="sub">소프트웨어융합학과 (휴학)</span></div>
        </a>
      </div>

    </aside>
  </div>

  <ExternalChannels />
</section>

<!-- ========== SKILLS ========== -->
<section id="skills">
  <div class="section-head">
    <div class="label"><span class="idx">02</span>Skills</div>
    <h2>잘 하는 것, 그리고 <em>아직 응애인 것</em></h2>
  </div>

  <div class="skills-grid">
    <div class="skill-col">
      <h3>Languages · 언어</h3>
      <div class="skill-tier" data-level="1">
        <div class="tier"><span class="lv"></span>고수</div>
        <div class="items">
          <span class="chip">한국어</span>
          <span class="chip">엔트리</span>
        </div>
      </div>
      <div class="skill-tier" data-level="2">
        <div class="tier"><span class="lv"></span>중수</div>
        <div class="items">
          <span class="chip">C / C++</span>
          <span class="chip">C#</span>
        </div>
      </div>
      <div class="skill-tier" data-level="3">
        <div class="tier"><span class="lv"></span>하수</div>
        <div class="items">
          <span class="chip">HTML</span>
          <span class="chip">JavaScript</span>
          <span class="chip">CSS</span>
          <span class="chip">Python</span>
        </div>
      </div>
    </div>

    <div class="skill-col">
      <h3>Tools · 도구</h3>
      <div class="skill-tier" data-level="1">
        <div class="tier"><span class="lv"></span>고수</div>
        <div class="items">
          <button class="chip secret" id="secret-chip" type="button">젓가락질</button>
          <div class="secret-msg">포크도 잘 사용함 🍴 (이건 비밀이에요)</div>
        </div>
      </div>
      <div class="skill-tier" data-level="2">
        <div class="tier"><span class="lv"></span>중수</div>
        <div class="items">
          <span class="chip">Unity</span>
        </div>
      </div>
      <div class="skill-tier" data-level="3">
        <div class="tier"><span class="lv"></span>하수</div>
        <div class="items">
          <span class="chip">Unreal Engine</span>
          <span class="chip">Firebase</span>
        </div>
      </div>
      <div class="skill-tier" data-level="4">
        <div class="tier"><span class="lv"></span>응애</div>
        <div class="items">
          <span class="chip">Blender</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ========== WORKS / GALLERY (data-driven) ========== -->
<WorksGallery projects={projects} />

<!-- ========== HIGHLIGHTS ========== -->
<section id="highlights" class="highlights">
  <div class="section-head">
    <div class="label"><span class="idx">04</span>Highlights</div>
    <h2>특히 자랑하고 싶은 <em>네 가지</em></h2>
  </div>
  <div class="highlight-grid">
    <a class="highlight is-mood" href="https://www.yes24.com/24/AuthorFile/Author/437179" target="_blank" rel="noopener">
      <div class="num">01 / 책</div>
      <h4>「나는야 엔트리<br/>게임 개발자」 출간</h4>
      <p>원큐패스 · Yes24 / 교보문고에서 만나요.</p>
      <span class="arrow">→</span>
    </a>
    <a class="highlight is-pink" href="https://namu.wiki/w/%EC%9D%B4%EC%98%81%ED%98%B8(2003)" target="_blank" rel="noopener">
      <div class="num">02 / 등재</div>
      <h4>나무위키<br/>「이영호(2003)」</h4>
      <p>본인이 작성하지 않았다는 게 포인트.</p>
      <span class="arrow">→</span>
    </a>
    <a class="highlight is-mint" href="#works">
      <div class="num">03 / 사이트</div>
      <h4>코난 정주행<br/>가이드 사이트</h4>
      <p>주요 에피소드를 한눈에. jQuery 정적 사이트.</p>
      <span class="arrow">→</span>
    </a>
    <a class="highlight" href="#works">
      <div class="num">04 / 강연</div>
      <h4>SEF2023<br/>EDC 발표자</h4>
      <p>Software Education Festival 2023.</p>
      <span class="arrow">→</span>
    </a>
  </div>
</section>

<!-- ========== AWARDS ========== -->
<Awards />

<!-- ========== FOOTER ========== -->
<footer class="foot" id="contact">
  <div class="foot-205" role="img" aria-label="205"></div>
  <div class="foot-grid">
    <div>
      <h5>Contact</h5>
      <div class="big">메일 보내주세요.</div>
      <p>강연·자문·협업·그냥 인사 — 무엇이든.</p>
      <a class="email" href="mailto:205@205.kr">→ 205@205.kr</a>
      <a class="email" href="mailto:youngholee205205@gmail.com">→ youngholee205205@gmail.com</a>
    </div>
    <div>
      <h5>Site</h5>
      <a href="https://205.kr">205.kr</a>
      <a href="http://xn--vj5bn0ab83a.com">이영호.com</a>
      <a href="https://entry.205.kr">entry.205.kr</a>
      <a href="https://xn--oy2b95t44j.org">엔트리.org</a>
    </div>
    <div>
      <h5>Channels</h5>
      <a href="https://github.com/205sla" target="_blank" rel="noopener">GitHub</a>
      <a href="https://www.youtube.com/@205" target="_blank" rel="noopener">YouTube</a>
      <a href="https://www.instagram.com/205_youngholee/" target="_blank" rel="noopener">Instagram</a>
      <a href="https://band.us/@entryband" target="_blank" rel="noopener">엔트리 밴드</a>
    </div>
    <div>
      <h5>Credits</h5>
      <p>Icons8 · <a href="https://icons8.com/" target="_blank" rel="noopener" style="display:inline; color:var(--mint);">icons8.com</a></p>
      <p style="margin-top: 8px;">원본 노션 · <a href="https://notion.so" target="_blank" rel="noopener" style="display:inline; color:var(--mint);">notion.so</a></p>
      <p style="margin-top: 8px;">디자인 · 205 Design System</p>
    </div>
  </div>
  <div class="foot-bottom">
    <span>© 2026 이영호 / 205 · All works are mine, all words are mine.</span>
    <span class="tm">™ KIPO 40-2334925</span>
  </div>
</footer>

<script>
  import { setupScrollProgress } from '@/scripts/scroll-progress';
  import { setupSectionScrollDots } from '@/scripts/section-scroll-dots';
  import { setupSecretChip } from '@/scripts/secret-chip';
  import { setupCodeTyping } from '@/scripts/code-typing';
  import { setupHeroEasterEgg } from '@/scripts/hero-easter-egg';

  setupScrollProgress('scroll-i');
  setupSectionScrollDots();
  setupSecretChip();
  setupCodeTyping();
  setupHeroEasterEgg();
  // Filter chips: handled in WorksGallery.astro (with pagination logic).
</script>

</BaseLayout>

---
import type { CollectionEntry } from 'astro:content';
import { CATEGORY_LABEL } from '@/lib/labels';

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const cat = CATEGORY_LABEL[entry.data.category];
const { title, year, dateRange, team, tags, result, links, icon_emoji } = entry.data;

const externals: Array<{ label: string; url: string; primary?: boolean }> = [];
if (links.youtube) externals.push({ label: '영상 ↗', url: links.youtube, primary: true });
if (links.store)   externals.push({ label: 'Play 스토어 ↗', url: links.store });
if (links.github)  externals.push({ label: 'GitHub ↗', url: links.github });
if (links.site)    externals.push({ label: '사이트 ↗', url: links.site });
for (const o of links.others ?? []) {
  externals.push({ label: `${o.label} ↗`, url: o.url });
}
---
<section class="page-header">
  <span class="cat-pill"><span class="ico">{cat.icon}</span>{cat.ko}</span>
  {icon_emoji && <span class="icon-emoji">{icon_emoji}</span>}
  <h1>{title}</h1>
  <div class="meta-row">
    {(dateRange || year) && (
      <div class="field">
        <span class="lab">기간</span>
        <span class="val">{dateRange ?? year}</span>
      </div>
    )}
    {team && (
      <div class="field">
        <span class="lab">팀</span>
        <span class="val">{team}</span>
      </div>
    )}
    {result && (
      <div class="field">
        <span class="lab">결과</span>
        <span class="val">{result}</span>
      </div>
    )}
    {tags.length > 0 && (
      <div class="field">
        <span class="lab">태그</span>
        {tags.map(t => <span class="tag">{t}</span>)}
      </div>
    )}
  </div>
  {externals.length > 0 && (
    <div class="external-row">
      {externals.map(x => (
        <a class={`ext-btn${x.primary ? '' : ' ghost'}`} href={x.url} target="_blank" rel="noopener">
          {x.label}
        </a>
      ))}
    </div>
  )}
</section>

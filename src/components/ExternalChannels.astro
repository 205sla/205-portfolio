---
<section class="external-channels" aria-labelledby="external-channels-heading">
  <h4 id="external-channels-heading">외부 채널</h4>
  <div class="channel-grid">
    {CHANNELS.map(ch => {
      const meta = ICON[ch.icon];
      return (
        <a class="channel-card" href={ch.url} target="_blank" rel="noopener" style={`--brand: ${meta.color};`}>
          <span class="ico" aria-hidden="true">
            <svg viewBox={meta.viewBox ?? '0 0 24 24'} width="22" height="22">
              <path d={meta.path} fill="currentColor" />
            </svg>
          </span>
          <span class="text">
            <span class="lbl">{ch.label}</span>
            {ch.sub && <span class="sub">{ch.sub}</span>}
          </span>
          <span class="arrow" aria-hidden="true">↗</span>
        </a>
      );
    })}
  </div>
</section>

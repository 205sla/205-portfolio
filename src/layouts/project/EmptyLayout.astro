---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import ProjectBase from './ProjectBase.astro';
import ProjectHeader from '@/components/project/ProjectHeader.astro';
import RelatedNav from '@/components/project/RelatedNav.astro';

interface Props {
  entry: CollectionEntry<'projects'>;
  headings: MarkdownHeading[];
  prev: CollectionEntry<'projects'> | null;
  next: CollectionEntry<'projects'> | null;
}

const { entry, prev, next } = Astro.props;
const notion = entry.data.links.notion;
---
<ProjectBase entry={entry}>
  <ProjectHeader entry={entry} />

  <div class="empty-state">
    <div class="glyph">···</div>
    <h3>이 페이지는 노션 원본에서 관리되고 있어요</h3>
    <p>
      외부 링크에 더 자세한 기록이 있어요.<br />
      아래 링크로 이동해 주세요.
    </p>
    <div class="row">
      {notion && (
        <a class="ext-btn" href={notion} target="_blank" rel="noopener">
          노션 원본에서 보기 ↗
        </a>
      )}
      <a class="ext-btn ghost" href="/#works">갤러리로 돌아가기</a>
    </div>
    <div style="margin-top: 32px; max-width: 660px; text-align: left;">
      <slot />
    </div>
  </div>

  <RelatedNav prev={prev} next={next} />
</ProjectBase>
